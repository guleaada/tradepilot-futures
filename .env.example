# =========================================================================
# TradePilot-Futures — USD-M FUTURES TESTNET fork (long + short). NO REAL
# FUNDS: the executor base URL is hard-coded to testnet.binancefuture.com and
# no mainnet executor exists in this codebase.
# =========================================================================

# --- execution (required for live testnet cycles) ---
# Keys from https://testnet.binancefuture.com (futures testnet — these do NOT
# work on mainnet, and spot-testnet keys do not work here).
BINANCE_FUTURES_TESTNET_API_KEY=
BINANCE_FUTURES_TESTNET_API_SECRET=

# Leverage per symbol (isolated margin). 3 is the tested default; the hard
# ceiling is 5 (MAX_ALLOWED_LEVERAGE in src/config.js) pending 30 days of
# data — higher values are clamped to 5 and logged as LEVERAGE_CLAMPED.
FUTURES_LEVERAGE=3

# --- AI layer ---
# Required for live regime calls (cycles still run without it; the rule
# engine just falls back to a no-trade "chop" regime).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional free pre-filter. Leave empty to skip the Groq step entirely.
GROQ_API_KEY=

# NOTE: no Grok/xAI sentiment layer in this fork — the xAI Live Search API is
# deprecated, so it was left out entirely.

# Hard daily cap on Anthropic spend (USD).
AI_DAILY_BUDGET_USD=0.50

# Model + pricing constants used for spend estimation (USD per million tokens).
AI_MODEL=claude-sonnet-4-6
AI_PRICE_INPUT_MTOK=3.0
AI_PRICE_OUTPUT_MTOK=15.0

# --- trading (all optional, defaults shown) ---
# Expanded universe of liquid USD-M perps. MAX_POSITIONS stays 2 — more pairs
# means more setups for the same 2 slots, not more concurrent risk.
PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,AVAXUSDT,LINKUSDT,APTUSDT,ARBUSDT,INJUSDT,SUIUSDT,TIAUSDT,DOGEUSDT,NEARUSDT,LTCUSDT
# Pairs with FUTURES 24h quote volume below this are excluded for the run
# (spot volume is the proxy where the futures endpoint is geo-blocked). A
# failed or zero/NaN volume lookup KEEPS the pair (LIQUIDITY_CHECK_UNAVAILABLE).
LIQUIDITY_MIN_VOLUME_24H=10000000
CYCLE_MINUTES=15
AI_CADENCE_HOURS=4
START_BALANCE=1000
# Risk is 1% of equity per trade from the ATR stop distance — NEVER from
# leverage. Leverage only changes the margin a position locks.
RISK_PER_TRADE=0.01
STOP_ATR_MULT=1.5
# Fixed TP multiple — only used when DYNAMIC_TP_ENABLED=false.
TP_ATR_MULT=2.5

# --- trend-scaled dynamic take-profit ---
# TP distance scales with ADX(14) on the 4h candles; the STOP never changes
# (risk fixed, reward widens in strong trends). false = fixed TP_ATR_MULT.
DYNAMIC_TP_ENABLED=true
TP_ATR_MULT_WEAK=2.0
TP_ATR_MULT_NORMAL=2.5
TP_ATR_MULT_STRONG=4.5
# ADX >= ADX_STRONG -> strong; ADX < ADX_WEAK -> weak; otherwise normal.
ADX_STRONG=30
ADX_WEAK=18
MAX_POSITIONS=2
MAX_NOTIONAL_PCT=0.25
DAILY_DRAWDOWN_HALT=0.03
COOLDOWN_HOURS=4
SLIPPAGE=0.0005
# USD-M futures taker fee (0.04% per side).
TAKER_FEE=0.0004

# --- futures risk controls ---
# Liquidation must sit at least this multiple of the stop distance from
# entry; otherwise size is reduced (SIZE_REDUCED_FOR_LIQ_BUFFER).
LIQ_BUFFER_MULT=1.25
# Maintenance margin rate used in the liquidation estimate.
MAINT_MARGIN_RATE=0.005
# Total open notional <= equity * leverage * this fraction (never use more
# than half the leveraged buying power). Blocks log LEVERAGE_EXPOSURE_CAP.
LEVERAGE_EXPOSURE_CAP_FRACTION=0.5

# --- entry bands ---
RSI_ENTRY_MIN=45
RSI_ENTRY_MAX=70
# Symmetric short band: not oversold, not knife-catching a bounce.
RSI_SHORT_ENTRY_MIN=30
RSI_SHORT_ENTRY_MAX=55

# --- entry filters (set any to false to restore the plain behavior) ---
VOLUME_FILTER_ENABLED=true
VOLUME_MIN_RATIO=1.1
# Longs need price above the daily EMA(50); shorts need price below it.
MTF_DAILY_FILTER_ENABLED=true
# ATR-percentile RSI zones (short zones mirror the long zones around 50).
DYNAMIC_RSI_ENABLED=true
CORRELATION_FILTER_ENABLED=true
CORRELATION_MAX=0.85
# Opt-in: block new entries Fri 20:00 UTC -> Sun 20:00 UTC.
WEEKEND_FILTER_ENABLED=false

# --- trailing stop + partial exits (symmetric for shorts) ---
TRAILING_STOP_ENABLED=true
BREAKEVEN_R=1.5
PARTIAL_EXIT_R=2.0
PARTIAL_EXIT_FRACTION=0.5
EXTENDED_TP_R=4.0

# --- regime-dependent risk sizing (direction-aware) ---
REGIME_RISK_SCALING_ENABLED=true
RISK_PCT_HIGH_CONF=0.015
MAX_NOTIONAL_HIGH_CONF=0.30
HIGH_CONF_THRESHOLD=80

# --- emergency price-action exit (adverse move, direction-aware) ---
EMERGENCY_EXIT_ENABLED=true
EMERGENCY_EXIT_DROP_PCT=0.05

# --- volatility targeting ---
VOL_TARGETING_ENABLED=true
VOL_TARGET_ANNUALIZED=0.40

# --- Telegram alerts (optional; alerts are a silent no-op when unset) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to 1 to run fully offline with synthetic data, a canned AI regime, and
# a mock futures transport (opens a long AND a short in the demo).
# TRADEPILOT_MOCK=1
